{
  "id": "Cattail_TweaksQuality_Better-UIs",
  "uniqueId": "Cattail_TweaksQuality_Better-UIs",
  "name": "Better UIs",
  "version": "0.1.0",
  "previousVersion": {
    "name": "Interface Pack",
    "version": "0.1.0"
  },
  "loaderVersion": ">=0.1.0",
  "languageSupport": {
    "gameLanguage": true
  },
  "entries": [
    "scripts/shop-categories.js",
    "scripts/save-slots.js",
    "scripts/language-menu.js",
    "scripts/settings-page.js"
  ],
  "conflicts": [
    "Cattail_TweaksQuality_Language-Menu",
    "Cattail_TweaksQuality_Saves-Slots",
    "Cattail_TweaksQuality_Shop-Categories"
  ],
  "config": {
    "enableShopCategories": {
      "type": "boolean",
      "label": "Shop categories",
      "default": true,
      "description": "Show the optional categorized compact building shop view.",
      "section": "shopCategories"
    },
    "enableSaveSlots": {
      "type": "boolean",
      "label": "Save slots",
      "default": true,
      "description": "Show the in-game save-slot page with import and export actions.",
      "section": "saveSlots"
    },
    "enableLanguageMenu": {
      "type": "boolean",
      "label": "Language menu",
      "default": true,
      "description": "Use the scrollable language selection page on the splash menu.",
      "section": "languageMenu"
    },
    "enableSettingsPage": {
      "type": "boolean",
      "label": "Settings page",
      "default": true,
      "description": "Add the in-game settings page to the splash menu.",
      "section": "settingsPage"
    }
  },
  "description": "Combines shop categories, save slots, and the language menu into one multi-entry interface quality mod.",
  "reloadOnConfigChange": true,
  "translations": {
